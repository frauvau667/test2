<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>KI Tennis-Experte Saarland</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f0f2f5; margin: 0; padding: 20px; }
        .chat-container { max-width: 900px; margin: auto; background: white; border-radius: 12px; shadow: 0 4px 15px rgba(0,0,0,0.1); display: flex; flex-direction: column; height: 80vh; }
        .header { background: #004d99; color: white; padding: 20px; border-top-left-radius: 12px; border-top-right-radius: 12px; }
        #chat-window { flex-grow: 1; padding: 20px; overflow-y: auto; border-bottom: 1px solid #ddd; }
        .message { margin-bottom: 15px; padding: 10px 15px; border-radius: 8px; max-width: 80%; }
        .user { background: #e1f5fe; align-self: flex-end; margin-left: auto; }
        .ai { background: #f1f1f1; align-self: flex-start; border-left: 4px solid #004d99; }
        .input-area { padding: 20px; display: flex; gap: 10px; }
        input[type="text"] { flex-grow: 1; padding: 12px; border: 1px solid #ccc; border-radius: 6px; }
        button { padding: 10px 20px; background: #004d99; color: white; border: none; border-radius: 6px; cursor: pointer; }
        .key-area { font-size: 0.8em; padding: 10px; background: #fff3e0; text-align: center; }
    </style>
</head>
<body>

<div class="chat-container">
    <div class="header">
        <h2>🎾 KI-Regel-Experte (STB / DTB)</h2>
        <p>A-Klasse bis Regionalliga & Turnierbetrieb</p>
    </div>
    
    <div class="key-area">
        API-Key benötigt: <input type="password" id="apiKey" placeholder="OpenAI API Key hier einfügen">
    </div>

    <div id="chat-window">
        <div class="message ai">Hallo! Ich kenne die Wettspielordnungen des STB und DTB (Stand 2025/26). Fragen Sie mich nach Aufstellungen, Match-Tie-Breaks oder Problemfällen.</div>
    </div>

    <div class="input-area">
        <input type="text" id="userInput" placeholder="Ihre Frage (z.B. 'Dritter Satz im Doppel?')">
        <button onclick="askAI()">Fragen</button>
    </div>
</div>

<script>
    // Zusammengefasstes Wissen aus Ihren Quellen als Kontext für die KI
    const TENNIS_KNOWLEDGE = `
    KONTEX-WISSEN FÜR DIE KI:
    - STB (Saarland): 3. Satz ist IMMER Match-Tie-Break (10 Punkte) [1].
    - STB Wertung: Einzel 2 Punkte, Doppel 3 Punkte. Gesamt max 21 (6er) oder 14 (4er) [1].
    - Verspätung STB: 15 Min nach Aufruf = 6:0, 6:0 Wertung [2]. 60 Min nach offizieller Zeit = Mannschaft nicht angetreten.
    - Regionalliga: Spielt nach DTB-WSpO [3].
    - DTB-TO §38.2: Werbung für andere Sport-Events auf Kleidung verboten [4, 5].
    - Kleidung: Bei falschem Schuhwerk (z.B. keine Sandplatzschuhe) 15 Min Zeit zum Wechseln, sonst Disqualifikation [6, 7].
    - Lucky Loser: Auch Spieler, die nach einer Rast in Runde 1 krank werden, können durch LL ersetzt werden [5, 8].
    - Schiedsrichter: Spieler entscheidet auf seiner Seite. Bei Ballabdruck-Streit auf Sand entscheidet der OSR endgültig [9, 10].
    - Behinderung: Absichtliches Sprechen während des Schlags ist Punktverlust [11, 12].
    - Aufstellung: Reihenfolge nach LK/Rangliste zwingend. Falsche Position = 0:6, 0:6 für dieses und alle folgenden Spiele [13, 14].
    `;

    async function askAI() {
        const apiKey = document.getElementById('apiKey').value;
        const input = document.getElementById('userInput').value;
        if (!apiKey) { alert("Bitte erst den API-Key eingeben!"); return; }
        
        appendMessage('user', input);
        document.getElementById('userInput').value = '';

        try {
            const response = await fetch('https://api.openai.com/1/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': 'Bearer ' + apiKey
                },
                body: JSON.stringify({
                    model: "gpt-3.5-turbo",
                    messages: [
                        { role: "system", content: "Du bist ein Experte für Tennis-Regeln im Saarland (STB) und überregional (DTB). Nutze folgendes Wissen: " + TENNIS_KNOWLEDGE },
                        { role: "user", content: input }
                    ]
                })
            });
            const data = await response.json();
            const aiReply = data.choices.message.content;
            appendMessage('ai', aiReply);
        } catch (e) {
            appendMessage('ai', "Fehler: Verbindung zur KI fehlgeschlagen. Prüfe den Key.");
        }
    }

    function appendMessage(sender, text) {
        const win = document.getElementById('chat-window');
        const div = document.createElement('div');
        div.className = 'message ' + sender;
        div.innerText = text;
        win.appendChild(div);
        win.scrollTop = win.scrollHeight;
    }
</script>
</body>
</html>
